# ============================================================
# Propvio Spring Boot Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── MySQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=propvio_db
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secure_jwt_secret_at_least_32_characters_long

# ── Email (Gmail SMTP) ────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# ── Frontend URL ──────────────────────────────────────────────
WEBSITE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# ── Spring AI / OpenAI ────────────────────────────────────────
# Get free API key from: https://platform.openai.com/api-keys
# gpt-4o-mini is very cheap (~$0.15 per million tokens)
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_MODEL=gpt-4o-mini

# ── ImageKit (optional — for image uploads) ───────────────────

IMAGEKIT_PUBLIC_KEY="public_BbwXeC384KyK3b+bXoG85BEBkfI="
IMAGEKIT_PRIVATE_KEY="private_pldW7W3uvvY44DTVaKYTdPW1K/A="
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/bd0lxd0ai"