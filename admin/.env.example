# ==========================================
# Propvio Admin Environment Variables
# ==========================================
# Copy this file to .env.local for local development.

# Backend API URL used by admin API client
# Local development: leave EMPTY so Vite proxy forwards /api/* to port 8080 (no CORS)
# VITE_BACKEND_URL=
# Production: set to the deployed backend URL
# VITE_BACKEND_URL=https://real-estate-website-backend-zfu7.onrender.com
